<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Police Case Reporting Portal | Government of India</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #1D4ED8;
            --primary-dark: #1E3A8A;
            --secondary: #2563EB;
            --accent: #10B981;
            --danger: #EF4444;
            --warning: #F59E0B;
            --bg: #F8FAFC;
            --card: #FFFFFF;
            --text: #1E293B;
            --text-light: #64748B;
            --border: #E2E8F0;
            --glass-bg: rgba(255, 255, 255, 0.25);
            --glass-border: rgba(255, 255, 255, 0.4);
            --glass-shadow: 0 8px 32px rgba(31, 38, 135, 0.15);
            --radius: 16px;
            --radius-sm: 10px;
            --radius-xs: 8px;
            --transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            --font-primary: 'Poppins', sans-serif;
            --font-secondary: 'Inter', sans-serif;
            --navbar-height: 70px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
            font-size: 16px;
        }

        body {
            font-family: var(--font-secondary);
            background: var(--bg);
            color: var(--text);
            line-height: 1.6;
            overflow-x: hidden;
            min-height: 100vh;
            background: linear-gradient(135deg, #f0f4ff 0%, #e8f0fe 25%, #f8fafc 50%, #eef2ff 75%, #f0f4ff 100%);
            background-attachment: fixed;
        }

        /* Floating Background Shapes */
        .bg-shapes {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
            overflow: hidden;
        }
        .bg-shape {
            position: absolute;
            border-radius: 50%;
            opacity: 0.07;
            animation: floatShape 20s infinite ease-in-out;
        }
        .bg-shape:nth-child(1) {
            width: 400px;
            height: 400px;
            background: var(--primary);
            top: -100px;
            right: -100px;
            animation-delay: 0s;
        }
        .bg-shape:nth-child(2) {
            width: 300px;
            height: 300px;
            background: var(--secondary);
            bottom: -80px;
            left: -80px;
            animation-delay: -7s;
        }
        .bg-shape:nth-child(3) {
            width: 250px;
            height: 250px;
            background: var(--accent);
            top: 40%;
            left: 60%;
            animation-delay: -14s;
        }
        .bg-shape:nth-child(4) {
            width: 200px;
            height: 200px;
            background: var(--warning);
            top: 20%;
            left: 10%;
            animation-delay: -3s;
        }
        .bg-shape:nth-child(5) {
            width: 350px;
            height: 350px;
            background: #6366f1;
            bottom: 20%;
            right: 15%;
            animation-delay: -10s;
        }

        @keyframes floatShape {
            0%,
            100% {
                transform: translateY(0) rotate(0deg) scale(1);
            }
            25% {
                transform: translateY(-40px) rotate(5deg) scale(1.05);
            }
            50% {
                transform: translateY(-20px) rotate(-3deg) scale(0.95);
            }
            75% {
                transform: translateY(-50px) rotate(2deg) scale(1.02);
            }
        }

        /* Page Loader */
        .page-loader {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: #fff;
            z-index: 99999;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: opacity 0.5s ease, visibility 0.5s ease;
        }
        .page-loader.hidden {
            opacity: 0;
            visibility: hidden;
            pointer-events: none;
        }
        .loader-ring {
            width: 60px;
            height: 60px;
            border: 5px solid var(--border);
            border-top-color: var(--primary);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* Toast Container */
        .toast-container {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 10px;
            pointer-events: none;
        }
        .toast {
            background: white;
            border-radius: var(--radius-xs);
            padding: 14px 20px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.18);
            display: flex;
            align-items: center;
            gap: 10px;
            font-family: var(--font-secondary);
            font-size: 0.9rem;
            font-weight: 500;
            min-width: 300px;
            pointer-events: auto;
            animation: slideInRight 0.4s ease, fadeOutRight 0.4s ease 3s forwards;
            border-left: 4px solid var(--accent);
        }
        .toast.error {
            border-left-color: var(--danger);
        }
        .toast.warning {
            border-left-color: var(--warning);
        }
        .toast-icon {
            font-size: 1.3rem;
            flex-shrink: 0;
        }
        @keyframes slideInRight {
            from {
                transform: translateX(120%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }
        @keyframes fadeOutRight {
            from {
                transform: translateX(0);
                opacity: 1;
            }
            to {
                transform: translateX(60px);
                opacity: 0;
            }
        }

        /* Navbar */
        .navbar {
            position: sticky;
            top: 0;
            z-index: 1000;
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.5);
            box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
            height: var(--navbar-height);
            transition: var(--transition);
        }
        .navbar.scrolled {
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
            background: rgba(255, 255, 255, 0.92);
        }
        .navbar-inner {
            max-width: 1300px;
            margin: 0 auto;
            padding: 0 24px;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .nav-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            cursor: pointer;
        }
        .nav-logo {
            width: 44px;
            height: 44px;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.4rem;
            font-weight: 700;
            box-shadow: 0 4px 16px rgba(29, 78, 216, 0.3);
        }
        .nav-brand-text {
            font-family: var(--font-primary);
            font-weight: 700;
            font-size: 1.1rem;
            color: var(--text);
            line-height: 1.2;
        }
        .nav-brand-text small {
            display: block;
            font-weight: 400;
            font-size: 0.7rem;
            color: var(--text-light);
            letter-spacing: 0.5px;
        }
        .nav-links {
            display: flex;
            list-style: none;
            gap: 6px;
            align-items: center;
        }
        .nav-links a {
            text-decoration: none;
            color: var(--text);
            font-family: var(--font-secondary);
            font-weight: 500;
            font-size: 0.9rem;
            padding: 8px 16px;
            border-radius: 25px;
            transition: var(--transition);
            cursor: pointer;
            white-space: nowrap;
        }
        .nav-links a:hover,
        .nav-links a.active {
            background: rgba(29, 78, 216, 0.08);
            color: var(--primary);
        }
        .nav-btn {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: white !important;
            padding: 10px 22px !important;
            border-radius: 25px !important;
            font-weight: 600 !important;
            box-shadow: 0 4px 16px rgba(29, 78, 216, 0.3);
            transition: var(--transition);
        }
        .nav-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(29, 78, 216, 0.4);
            background: linear-gradient(135deg, var(--primary-dark), var(--primary)) !important;
            color: white !important;
        }
        .nav-btn-outline {
            border: 2px solid var(--primary) !important;
            color: var(--primary) !important;
            background: transparent !important;
            padding: 8px 20px !important;
            border-radius: 25px !important;
            font-weight: 600 !important;
        }
        .nav-btn-outline:hover {
            background: var(--primary) !important;
            color: white !important;
        }
        .hamburger {
            display: none;
            flex-direction: column;
            gap: 5px;
            cursor: pointer;
            background: none;
            border: none;
            padding: 8px;
            z-index: 1001;
        }
        .hamburger span {
            width: 28px;
            height: 3px;
            background: var(--text);
            border-radius: 3px;
            transition: var(--transition);
        }
        .hamburger.active span:nth-child(1) {
            transform: rotate(45deg) translate(5px, 6px);
        }
        .hamburger.active span:nth-child(2) {
            opacity: 0;
        }
        .hamburger.active span:nth-child(3) {
            transform: rotate(-45deg) translate(5px, -6px);
        }

        /* Main Content */
        .main-content {
            position: relative;
            z-index: 1;
            max-width: 1300px;
            margin: 0 auto;
            padding: 0 24px;
            min-height: calc(100vh - var(--navbar-height) - 60px);
        }
        .page-section {
            display: none;
            animation: fadeSlideIn 0.5s ease;
        }
        .page-section.active {
            display: block;
        }
        @keyframes fadeSlideIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Hero Banner */
        .hero {
            display: flex;
            align-items: center;
            gap: 48px;
            padding: 60px 0;
            flex-wrap: wrap;
        }
        .hero-content {
            flex: 1;
            min-width: 300px;
        }
        .hero-badge {
            display: inline-block;
            background: rgba(16, 185, 129, 0.12);
            color: var(--accent);
            padding: 6px 16px;
            border-radius: 25px;
            font-size: 0.85rem;
            font-weight: 600;
            margin-bottom: 16px;
            letter-spacing: 0.5px;
        }
        .hero h1 {
            font-family: var(--font-primary);
            font-size: 2.8rem;
            font-weight: 800;
            line-height: 1.2;
            color: var(--text);
            margin-bottom: 16px;
        }
        .hero h1 span {
            background: linear-gradient(135deg, var(--primary), #6366f1);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .hero p {
            font-size: 1.1rem;
            color: var(--text-light);
            margin-bottom: 28px;
            max-width: 500px;
        }
        .hero-buttons {
            display: flex;
            gap: 14px;
            flex-wrap: wrap;
        }
        .btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 13px 28px;
            border-radius: 30px;
            font-family: var(--font-secondary);
            font-weight: 600;
            font-size: 0.95rem;
            cursor: pointer;
            border: none;
            text-decoration: none;
            transition: var(--transition);
            white-space: nowrap;
            letter-spacing: 0.3px;
        }
        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: white;
            box-shadow: 0 6px 24px rgba(29, 78, 216, 0.35);
        }
        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 32px rgba(29, 78, 216, 0.45);
        }
        .btn-outline {
            border: 2px solid var(--primary);
            color: var(--primary);
            background: transparent;
        }
        .btn-outline:hover {
            background: var(--primary);
            color: white;
        }
        .btn-accent {
            background: var(--accent);
            color: white;
            box-shadow: 0 6px 20px rgba(16, 185, 129, 0.3);
        }
        .btn-accent:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 28px rgba(16, 185, 129, 0.4);
        }
        .btn-sm {
            padding: 8px 18px;
            font-size: 0.82rem;
            border-radius: 20px;
        }
        .hero-visual {
            flex: 1;
            min-width: 300px;
            display: flex;
            justify-content: center;
        }
        .hero-card {
            background: var(--glass-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius);
            padding: 32px;
            box-shadow: var(--glass-shadow);
            max-width: 420px;
            width: 100%;
            text-align: center;
        }
        .hero-card .shield-icon {
            font-size: 4rem;
            margin-bottom: 12px;
            animation: pulse 2s infinite;
        }
        @keyframes pulse {
            0%,
            100% {
                transform: scale(1);
            }
            50% {
                transform: scale(1.08);
            }
        }
        .hero-card h3 {
            font-family: var(--font-primary);
            font-weight: 700;
            margin-bottom: 6px;
        }
        .hero-card .emergency-number {
            font-size: 2rem;
            font-weight: 800;
            color: var(--danger);
            font-family: var(--font-primary);
            letter-spacing: 1px;
        }

        /* Section Titles */
        .section-title {
            text-align: center;
            margin-bottom: 40px;
        }
        .section-title h2 {
            font-family: var(--font-primary);
            font-size: 2rem;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 8px;
        }
        .section-title p {
            color: var(--text-light);
            font-size: 1rem;
        }
        .section-title h2 span {
            background: linear-gradient(135deg, var(--primary), #6366f1);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* Cards Grid */
        .cards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }
        .card {
            background: var(--card);
            border-radius: var(--radius);
            padding: 24px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
            transition: var(--transition);
            border: 1px solid transparent;
            cursor: pointer;
            position: relative;
            overflow: hidden;
        }
        .card:hover {
            transform: translateY(-6px);
            box-shadow: 0 16px 40px rgba(0, 0, 0, 0.12);
            border-color: rgba(29, 78, 216, 0.15);
        }
        .card-icon {
            width: 52px;
            height: 52px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            margin-bottom: 16px;
        }
        .card-icon.blue {
            background: rgba(29, 78, 216, 0.1);
            color: var(--primary);
        }
        .card-icon.green {
            background: rgba(16, 185, 129, 0.1);
            color: var(--accent);
        }
        .card-icon.orange {
            background: rgba(245, 158, 11, 0.1);
            color: var(--warning);
        }
        .card-icon.red {
            background: rgba(239, 68, 68, 0.1);
            color: var(--danger);
        }
        .card h3 {
            font-family: var(--font-primary);
            font-weight: 600;
            margin-bottom: 8px;
            font-size: 1.1rem;
        }
        .card p {
            color: var(--text-light);
            font-size: 0.9rem;
            line-height: 1.5;
        }

        /* Glass Card */
        .glass-card {
            background: var(--glass-bg);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius);
            padding: 28px;
            box-shadow: var(--glass-shadow);
            transition: var(--transition);
        }
        .glass-card:hover {
            box-shadow: 0 16px 40px rgba(31, 38, 135, 0.2);
            transform: translateY(-3px);
        }

        /* Stats */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 16px;
            margin-bottom: 32px;
        }
        .stat-card {
            background: var(--card);
            border-radius: var(--radius);
            padding: 20px 24px;
            text-align: center;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.05);
            transition: var(--transition);
            border-left: 4px solid var(--primary);
        }
        .stat-card.pending {
            border-left-color: var(--warning);
        }
        .stat-card.investigation {
            border-left-color: var(--secondary);
        }
        .stat-card.resolved {
            border-left-color: var(--accent);
        }
        .stat-card.rejected {
            border-left-color: var(--danger);
        }
        .stat-number {
            font-family: var(--font-primary);
            font-size: 2.2rem;
            font-weight: 800;
            color: var(--text);
        }
        .stat-label {
            color: var(--text-light);
            font-size: 0.85rem;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* Timeline */
        .timeline {
            position: relative;
            padding-left: 36px;
            margin: 24px 0;
        }
        .timeline::before {
            content: '';
            position: absolute;
            left: 15px;
            top: 0;
            bottom: 0;
            width: 3px;
            background: linear-gradient(to bottom, var(--accent), var(--primary), var(--secondary), #6366f1, var(--accent));
            border-radius: 3px;
        }
        .timeline-item {
            position: relative;
            margin-bottom: 28px;
            padding-left: 20px;
        }
        .timeline-item::before {
            content: '';
            position: absolute;
            left: -25px;
            top: 6px;
            width: 16px;
            height: 16px;
            border-radius: 50%;
            background: var(--card);
            border: 3px solid var(--primary);
            box-shadow: 0 0 0 6px rgba(29, 78, 216, 0.1);
            transition: var(--transition);
        }
        .timeline-item.completed::before {
            background: var(--accent);
            border-color: var(--accent);
            box-shadow: 0 0 0 6px rgba(16, 185, 129, 0.15);
        }
        .timeline-item.active::before {
            background: var(--primary);
            border-color: var(--primary);
            animation: pulseDot 1.5s infinite;
        }
        @keyframes pulseDot {
            0%,
            100% {
                box-shadow: 0 0 0 6px rgba(29, 78, 216, 0.1);
            }
            50% {
                box-shadow: 0 0 0 16px rgba(29, 78, 216, 0);
            }
        }
        .timeline-content h4 {
            font-family: var(--font-primary);
            font-weight: 600;
            margin-bottom: 4px;
            font-size: 1rem;
        }
        .timeline-content p {
            color: var(--text-light);
            font-size: 0.85rem;
        }
        .timeline-date {
            font-size: 0.75rem;
            color: var(--text-light);
            font-weight: 500;
        }

        /* Forms */
        .form-group {
            margin-bottom: 18px;
        }
        .form-group label {
            display: block;
            font-weight: 600;
            font-size: 0.88rem;
            margin-bottom: 6px;
            color: var(--text);
            font-family: var(--font-secondary);
        }
        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 12px 16px;
            border: 2px solid var(--border);
            border-radius: var(--radius-xs);
            font-family: var(--font-secondary);
            font-size: 0.9rem;
            transition: var(--transition);
            background: #FAFBFC;
            color: var(--text);
            resize: vertical;
        }
        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(29, 78, 216, 0.08);
            background: white;
        }
        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }
        .form-check {
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
        }
        .form-check input[type="checkbox"] {
            width: 18px;
            height: 18px;
            accent-color: var(--primary);
            cursor: pointer;
        }

        /* Tables */
        .table-container {
            overflow-x: auto;
            border-radius: var(--radius);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
        }
        table {
            width: 100%;
            border-collapse: collapse;
            background: var(--card);
            border-radius: var(--radius);
            overflow: hidden;
        }
        table thead {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: white;
        }
        table th {
            padding: 14px 16px;
            text-align: left;
            font-weight: 600;
            font-size: 0.85rem;
            letter-spacing: 0.3px;
            font-family: var(--font-primary);
        }
        table td {
            padding: 13px 16px;
            border-bottom: 1px solid var(--border);
            font-size: 0.9rem;
        }
        table tbody tr {
            transition: var(--transition);
        }
        table tbody tr:hover {
            background: rgba(29, 78, 216, 0.03);
        }
        .badge {
            display: inline-block;
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 0.78rem;
            font-weight: 600;
            letter-spacing: 0.3px;
        }
        .badge-pending {
            background: #FEF3C7;
            color: #92400E;
        }
        .badge-review {
            background: #DBEAFE;
            color: #1E40AF;
        }
        .badge-investigation {
            background: #EDE9FE;
            color: #5B21B6;
        }
        .badge-resolved {
            background: #D1FAE5;
            color: #065F46;
        }
        .badge-rejected {
            background: #FEE2E2;
            color: #991B1B;
        }

        /* Accordion */
        .accordion {
            border-radius: var(--radius);
            overflow: hidden;
        }
        .accordion-item {
            border: 1px solid var(--border);
            margin-bottom: 8px;
            border-radius: var(--radius-sm);
            overflow: hidden;
            background: var(--card);
            transition: var(--transition);
        }
        .accordion-header {
            padding: 16px 20px;
            cursor: pointer;
            font-weight: 600;
            font-family: var(--font-primary);
            display: flex;
            justify-content: space-between;
            align-items: center;
            user-select: none;
            transition: var(--transition);
